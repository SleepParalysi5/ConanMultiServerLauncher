<Window x:Class="ConanMultiServerLauncher.SteamModsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paste Steam Mods" Height="250" Width="500"
        WindowStartupLocation="CenterOwner" Background="#1E1E1E">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Paste Steam Workshop URLs, IDs, or .pak paths (one per line or mixed):" Foreground="White" Margin="0,0,0,10"/>
        
        <TextBox x:Name="ModsTextBox" Grid.Row="1" Background="#2D2D2D" Foreground="White" 
                 BorderBrush="#3F3F46" Padding="5" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="OK" Width="80" Margin="0,0,10,0" Click="Ok_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="80" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>

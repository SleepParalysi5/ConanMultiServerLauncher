<Window x:Class="ConanMultiServerLauncher.SteamCollectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paste Steam Collection" Height="200" Width="500"
        WindowStartupLocation="CenterOwner" Background="#1E1E1E">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Paste Steam Workshop Collection URL or ID:" Foreground="White" Margin="0,0,0,10"/>
        
        <TextBox x:Name="UrlTextBox" Grid.Row="1" Background="#2D2D2D" Foreground="White" 
                 BorderBrush="#3F3F46" Padding="5" VerticalAlignment="Top"/>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Margin="0,0,10,0" Click="Ok_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="80" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
